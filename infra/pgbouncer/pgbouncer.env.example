# PgBouncer (edoburu/pgbouncer image) configuration.
# Transaction-mode pooling keeps Postgres backend connections low even with
# many api replicas + executor workers opening Prisma pools.
DB_HOST=postgres
DB_PORT=5432
DB_USER=root
DB_PASSWORD=CHANGE_ME
DB_NAME=assessment_platform
POOL_MODE=transaction
MAX_CLIENT_CONN=10000
DEFAULT_POOL_SIZE=50
MIN_POOL_SIZE=10
RESERVE_POOL_SIZE=10
AUTH_TYPE=scram-sha-256
