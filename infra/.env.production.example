# ---- Copy to infra/.env.production and fill in real values. NEVER commit secrets. ----

# Postgres (direct, used by migrations/seed and PgBouncer upstream)
POSTGRES_USER=root
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=assessment_platform

# App DB connection goes THROUGH PgBouncer (port 6432), not Postgres directly.
# Prisma note: with PgBouncer transaction mode, append pgbouncer=true.
DATABASE_URL=postgresql://root:CHANGE_ME_STRONG@pgbouncer:6432/assessment_platform?pgbouncer=true&connection_limit=20

# Redis
REDIS_URL=redis://redis:6379

# Auth — REQUIRED in production (api fails fast without it, see MR-1)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_64_CHARS

# API hardening (MR-1)
# Comma-separated list of allowed browser origins (your public domain).
CORS_ORIGINS=https://exams.yourdomain.com
BODY_LIMIT=1mb
THROTTLE_LIMIT=120
THROTTLE_TTL_MS=60000

# Executor sandbox isolation — use gVisor in production.
SANDBOX_RUNTIME=runsc
AUTO_SUBMIT_CONCURRENCY=50

# Frontend build-time public vars (baked into web image)
NEXT_PUBLIC_API_URL=https://exams.yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=https://exams.yourdomain.com
